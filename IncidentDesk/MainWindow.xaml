<Window x:Class="IncidentDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Incident Desk" Height="600" Width="900">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="5">
            <TextBlock Text="Incident Desk" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock Text="Search" />
            <TextBox x:Name="txtSearch" Margin="0,0,0,10" TextChanged="txtSearch_TextChanged"/>

            <TextBlock Text="Filter by Status" />
            <ComboBox x:Name="cbFilterStatus" Margin="0,0,0,10" SelectionChanged="cbFilterStatus_SelectionChanged">
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="Open"/>
                <ComboBoxItem Content="In Progress"/>
                <ComboBoxItem Content="Resolved"/>
            </ComboBox>

            <TextBlock Text="Sort By" />
            <ComboBox x:Name="cbSort" Margin="0,0,0,10" SelectionChanged="cbSort_SelectionChanged">
                <ComboBoxItem Content="Date"/>
                <ComboBoxItem Content="Severity"/>
                <ComboBoxItem Content="Category"/>
            </ComboBox>

            <ListBox x:Name="lstIncidents" Height="300" SelectionChanged="lstIncidents_SelectionChanged"/>

            <Button Content="Save Data" Click="btnSave_Click" Margin="0,10,0,0"/>
            <Button Content="Load Data" Click="btnLoad_Click" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="15,5,5,5">
            <TextBlock Text="Incident Details" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock Text="Title" />
            <TextBox x:Name="txtTitle" Margin="0,0,0,10"/>

            <TextBlock Text="Severity" />
            <ComboBox x:Name="cbSeverity" Margin="0,0,0,10">
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
            </ComboBox>

            <TextBlock Text="Category" />
            <ComboBox x:Name="cbCategory" Margin="0,0,0,10">
                <ComboBoxItem Content="Phishing"/>
                <ComboBoxItem Content="Malware"/>
                <ComboBoxItem Content="Suspicious Login"/>
                <ComboBoxItem Content="Other"/>
            </ComboBox>

            <TextBlock Text="Status" />
            <ComboBox x:Name="cbStatus" Margin="0,0,0,10">
                <ComboBoxItem Content="Open"/>
                <ComboBoxItem Content="In Progress"/>
                <ComboBoxItem Content="Resolved"/>
            </ComboBox>

            <TextBlock Text="Notes" />
            <TextBox x:Name="txtNotes" Height="80" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal">
                <Button Content="Add" Width="80" Click="btnAdd_Click" Margin="0,0,5,0"/>
                <Button Content="Update" Width="80" Click="btnUpdate_Click" Margin="0,0,5,0"/>
                <Button Content="Delete" Width="80" Click="btnDelete_Click"/>
            </StackPanel>

            <TextBlock x:Name="txtDashboard" FontSize="16" FontWeight="Bold" Margin="0,30,0,0"/>
        </StackPanel>
    </Grid>
</Window>