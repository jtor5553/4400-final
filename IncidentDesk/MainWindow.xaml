<Window x:Class="IncidentDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Incident Desk"
        Height="650"
        Width="1000"
        Background="#F4F6F8"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#111827" CornerRadius="14" Padding="20" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Incident Desk"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold"/>

                <TextBlock Text="Cybersecurity Incident Case Tracker"
                           Foreground="#CBD5E1"
                           FontSize="14"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Card -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="14"
                    Padding="18"
                    Margin="0,0,10,0">

                <StackPanel>
                    <TextBlock Text="Incident List"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <TextBlock Text="Search"/>
                    <TextBox x:Name="txtSearch"
                             TextChanged="txtSearch_TextChanged"/>

                    <TextBlock Text="Filter by Status"/>
                    <ComboBox x:Name="cbFilterStatus"
                              SelectionChanged="cbFilterStatus_SelectionChanged">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Open"/>
                        <ComboBoxItem Content="In Progress"/>
                        <ComboBoxItem Content="Resolved"/>
                    </ComboBox>

                    <TextBlock Text="Sort By"/>
                    <ComboBox x:Name="cbSort"
                              SelectionChanged="cbSort_SelectionChanged">
                        <ComboBoxItem Content="Date"/>
                        <ComboBoxItem Content="Severity"/>
                        <ComboBoxItem Content="Category"/>
                    </ComboBox>

                    <ListBox x:Name="lstIncidents"
                             Height="280"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"
                             Background="#F8FAFC"
                             SelectionChanged="lstIncidents_SelectionChanged"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Save Data"
                                Width="110"
                                Click="btnSave_Click"/>

                        <Button Content="Load Data"
                                Width="110"
                                Background="#475569"
                                Click="btnLoad_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Right Card -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="14"
                    Padding="18"
                    Margin="10,0,0,0">

                <StackPanel>
                    <TextBlock Text="Incident Details"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <TextBlock Text="Title"/>
                    <TextBox x:Name="txtTitle"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Severity"/>
                            <ComboBox x:Name="cbSeverity">
                                <ComboBoxItem Content="Low"/>
                                <ComboBoxItem Content="Medium"/>
                                <ComboBoxItem Content="High"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8,0,8,0">
                            <TextBlock Text="Category"/>
                            <ComboBox x:Name="cbCategory">
                                <ComboBoxItem Content="Phishing"/>
                                <ComboBoxItem Content="Malware"/>
                                <ComboBoxItem Content="Suspicious Login"/>
                                <ComboBoxItem Content="Other"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                            <TextBlock Text="Status"/>
                            <ComboBox x:Name="cbStatus">
                                <ComboBoxItem Content="Open"/>
                                <ComboBoxItem Content="In Progress"/>
                                <ComboBoxItem Content="Resolved"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Notes"/>
                    <TextBox x:Name="txtNotes"
                             Height="110"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Add"
                                Width="90"
                                Click="btnAdd_Click"/>

                        <Button Content="Update"
                                Width="90"
                                Background="#16A34A"
                                Click="btnUpdate_Click"/>

                        <Button Content="Delete"
                                Width="90"
                                Background="#DC2626"
                                Click="btnDelete_Click"/>
                    </StackPanel>

                    <Border Background="#EFF6FF"
                            CornerRadius="12"
                            Padding="16"
                            Margin="0,25,0,0">

                        <TextBlock x:Name="txtDashboard"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#1D4ED8"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>